<addon id="service.skippy"
       name="Skippy - Video Segment Skipper"
       version="3.7.9"
       provider-name="Skippy-McSkipface">
       
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <!-- Optional: TMDB Helper requires script.module.jurialmunkey; listing it here helps Kodi
             resolve the chain when optional dependencies are installed (repo must ship the module,
             or install the module ZIP from jurialmunkey GitHub releases first). Skippy does not import it. -->
        <import addon="script.module.jurialmunkey" version="0.0.0" optional="true" />
        <import addon="plugin.video.themoviedb.helper" version="0.0.0" optional="true" />
    </requires>

    <extension point="xbmc.service" library="service.py" />

    <extension point="xbmc.python.script" library="skippy_runscript_entry.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Skippy: skip, mark, and edit video segments (intros, recaps, credits, and more) using local or online data.</summary>
        <description>All-in-one Kodi companion for chapter-style workflows: automatically skip or prompt on segments, mark new ranges during playback, and open a full segment editor for .edl and Matroska-style chapters.xml sidecars. Highly configurable keywords, EDL action types, dialogs, and optional online lookups (TheIntroDB / IntroDB.app). Separate keymaps for marker (skippy_marker.xml) and editor (skippy_editor.xml).</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
            <screenshot>screenshot01.png</screenshot>
            <screenshot>screenshot02.png</screenshot>
            <screenshot>screenshot03.png</screenshot>
        </assets>
    </extension>
</addon>