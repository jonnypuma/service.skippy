<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <category label="30000">

    <setting id="custom_segment_keywords"
             type="text"
             label="31000"
             default="intro,recap,prologue,epilogue,ad,ads,sponsor,sponsors,commercial,commercials,outro,credits,preview,next time on,next on,sneak peek,last time on,last on,previously on,closing,ending"
             tooltip="Comma-separated list of chapterstrings (case-insensitive) the skipper should monitor." />

    <setting type="lsep" label="31001" />

    <setting id="segment_always_skip"
             type="text"
             label="31002"
             default="commercial,commercials,sponsor,sponsors,ad,ads"
             tooltip="Subset of your segment keywords that should skip automatically." />

    <setting id="segment_ask_skip"
             type="text"
             label="31003"
             default="intro,recap,segment,preview,next time on,next on,sneak peek,last time on,last on,previously on"
             tooltip="Subset that should prompt you before skipping." />

    <setting id="segment_never_skip"
             type="text"
             label="31004"
             default="prologue,epilogue,main,credits,outro,closing,ending"
             tooltip="Subset to always play, never skip." />

	<setting id="ignore_internal_edl_actions" 
			 type="bool" 
			 label="31005" 
			 default="true" 
			 tooltip="Skippy will ignore any EDL segment whose action type is not explicitly mapped in edl_action_mapping. This includes Kodi's internal action types and any unknown or custom types without a defined label. If set to false it will fall back to label 'Segment'." />


    <setting id="edl_action_mapping"
             type="text"
             label="31006"
             default="4:Segment,5:Intro,6:Ad,7:Commercial,8:Credits,9:Recap,10:Prologue,11:Epilogue"
             tooltip="Format: action_type:label. Example: 4:Segment,5:Intro,6:Ad,7:Credits" />

	<setting id="skip_overlapping_segments" 
			 type="bool" 
			 label="31007" 
			 default="true"
			 tooltip="Configurable overlap detection to help avoid redundant or conflicting skips" />

    <setting type="lsep" label="32045" />

    <setting id="save_online_segments_to_chapters_xml"
             type="bool"
             label="32046"
             default="false"
             tooltip="32047" />

    <setting id="save_online_chapters_existing_policy"
             type="labelenum"
             label="32069"
             default="SkipIfExists"
             values="Skip if exists|Overwrite (no prompt)|Overwrite (ask first)|Merge with existing"
             optionvalues="SkipIfExists|OverwriteSilent|OverwriteAsk|Merge"
             tooltip="32070" />

    <setting id="save_online_chapters_backup_before_overwrite"
             type="bool"
             label="32071"
             default="true"
             tooltip="32072" />

  </category>

  <category label="30001">
    <setting type="lsep" label="32019" />

    <setting id="rewind_threshold_seconds"
             type="number"
             label="32008"
             default="8"
             min="2"
             max="30"
             tooltip="If playback jumps backward more than this threshold, skip prompts will reset. Helps avoid false triggers from buffering or auto-rewind addons." />

    <setting id="enable_skip_movies"
             type="bool"
             label="32010"
             default="true"
             tooltip="Enable skipping for movies. When disabled, no segments will be skipped (auto-skip or dialog) for movies." />

    <setting id="enable_skip_episodes"
             type="bool"
             label="32011"
             default="true"
             tooltip="Enable skipping for TV episodes. When disabled, no segments will be skipped (auto-skip or dialog) for episodes." />

    <setting id="show_skip_dialog_movies"
             type="bool"
             label="32017"
             default="true"
             tooltip="Show skip dialog for movies when behavior is set to ask. Requires 'Enable Skip for Movies' to be enabled." />

    <setting id="show_skip_dialog_episodes"
             type="bool"
             label="32018"
             default="true"
             tooltip="Show skip dialog for TV episodes when behavior is set to ask. Requires 'Enable Skip for Episodes' to be enabled." />

    <setting id="hide_ending_text"
             type="bool"
             label="32016"
             default="false"
             tooltip="Hide the segment countdown line for both Full and Minimal skip dialogs." />

    <setting id="skip_dialog_mode"
             type="labelenum"
             label="32020"
             default="Full"
             values="Full|Minimal"
             optionvalues="Full|Minimal"
             tooltip="Full: classic skip dialog with progress bar and icons. Minimal: single plate image and text only." />

    <setting id="skip_dialog_font_color"
             type="labelenum"
             label="32026"
             default="FFFFFFFF"
             values="White|Light grey|Grey|Dark grey|Black|Blue|Red|Green|Aquamarine|Pink|Purple|Peach|Orange|Yellow"
             optionvalues="FFFFFFFF|FF8E8E8E|FF6E6E6E|FF3D3D3D|FF000000|FF1976D2|FFE5392F|FF43A047|FF00ACC1|FFE91E63|FF8E24AA|FFFF8A65|FFEF6C00|FFF9A825"
             tooltip="Full and Minimal: color for skip dialog text (skip buttons, close, countdown, and next-jump line). Uses stored ARGB hex so Kodi always receives a valid color." />

    <setting type="lsep" label="32021" />

    <setting id="show_progress_bar"
             type="bool"
             label="32007"
             default="true"
             tooltip="Full mode: show or hide the progress bar while a skippable segment is active." />

    <setting id="skip_dialog_position"
             type="labelenum"
             label="32009"
             default="Bottom Right"
             values="Bottom Right|Top Right|Top Left|Bottom Left"
             optionvalues="BottomRight|TopRight|TopLeft|BottomLeft"
             tooltip="Full mode: which corner the skip dialog appears in during playback." />

    <setting id="button_focus_style"
             type="labelenum"
             label="32000"
             default="button_focus.png"
             values="button_focus.png|button_focus_aqua.png|button_focus_aqua_bevel.png|button_focus_aqua_dark.png|button_focus_aqua_vignette.png|button_focus_aqua_rounded.png|button_focus_blue.png|button_focus_blue_rectangular_3d.png|button_focus_blue_rounded_3d.png|button_focus_gold_rectangular_3d.png"
             optionvalues="Default|Aqua|Aqua Bevel|Aqua Dark|Aqua Vignette|Aqua Rounded|Blue|Blue Rectangular 3D|Blue Rounded 3D|Gold Rectangular 3D"
             tooltip="Full mode: focused texture for Skip and Close buttons." />

    <setting id="skip_button_format"
             type="labelenum"
             label="32013"
             default="Skip + Type + Duration"
             values="Skip|Skip + Type|Skip + Type + Duration"
             optionvalues="Skip|Skip + Type|Skip + Type + Duration"
             tooltip="Full mode: wording on the Skip action buttons." />

    <setting id="hide_close_button"
             type="bool"
             label="32014"
             default="false"
             tooltip="Full mode: hide the Close button and its icon." />

    <setting id="hide_skip_icon"
             type="bool"
             label="32015"
             default="false"
             tooltip="Full mode: hide both the skip and close icons." />

    <setting type="lsep" label="32022" />

    <setting id="minimal_button_style"
             type="labelenum"
             label="32023"
             default="minimal_rounded_gray_640.png"
             values="minimal_rounded_gray_640.png|minimal_rectangular_aquamarine-blue_640.png|minimal_rectangular_blue_640.png|minimal_rectangular_yellow_640.png|minimal_rounded_baby-purple_640.png|minimal_rounded_blue-red-gradient_640.png|minimal_rounded_bright-aqua_640.png|minimal_rounded_bright-blue-sky_640.png|minimal_rounded_bright-cyan_640.png|minimal_rounded_burnt-pink_640.png|minimal_rounded_cranberry_640.png|minimal_rounded_deep-pink_640.png|minimal_rounded_greyish-blue_640.png|minimal_rounded_languid-lavender_640.png|minimal_rounded_light-green-7284348_640.png|minimal_rounded_light-grey_640.png|minimal_rounded_light-yellow_640.png|minimal_rounded_minty-green_640.png|minimal_rounded_mustard-yellow_640.png|minimal_rounded_pale-gold_640.png|minimal_rounded_pale-sky-blue_640.png|minimal_rounded_pastel-green_640.png|minimal_rounded_pattens-blue_640.png|minimal_rounded_peach-orange_640.png|minimal_rounded_pink-daisy_640.png|minimal_rounded_pink-lemonade_640.png|minimal_rounded_pinkish-orange_640.png|minimal_rounded_sunset_640.png|minimal_rounded_white_640.png"
             optionvalues="Rounded Gray|Rectangular Aquamarine Blue|Rectangular Blue|Rectangular Yellow|Rounded Baby Purple|Rounded Blue Red Gradient|Rounded Bright Aqua|Rounded Bright Blue Sky|Rounded Bright Cyan|Rounded Burnt Pink|Rounded Cranberry|Rounded Deep Pink|Rounded Greyish Blue|Rounded Languid Lavender|Rounded Light Green 7284348|Rounded Light Grey|Rounded Light Yellow|Rounded Minty Green|Rounded Mustard Yellow|Rounded Pale Gold|Rounded Pale Sky Blue|Rounded Pastel Green|Rounded Pattens Blue|Rounded Peach Orange|Rounded Pink Daisy|Rounded Pink Lemonade|Rounded Pinkish Orange|Rounded Sunset|Rounded White"
             tooltip="Minimal mode: background art for the skip plate (PNG filenames; same storage pattern as Full mode button focus textures)." />

    <setting id="minimal_skip_button_format"
             type="labelenum"
             label="32025"
             default="Skip + Type"
             values="Skip|Skip + Type|Skip + Type + Duration"
             optionvalues="Skip|Skip + Type|Skip + Type + Duration"
             tooltip="Minimal mode: primary text shown on the skip plate." />

    <setting id="minimal_skip_dialog_position"
             type="labelenum"
             label="32024"
             default="Bottom Right"
             values="Bottom Right|Top Right|Top Left|Bottom Left"
             optionvalues="BottomRight|TopRight|TopLeft|BottomLeft"
             tooltip="Minimal mode: which corner the skip plate appears in during playback." />

  </category>

  <category label="30004">
    <setting type="lsep" label="32036" />

    <setting id="tv_tmdb_resolve_missing_ids"
             type="bool"
             label="32031"
             default="true"
             tooltip="32035" />

    <setting id="tv_tmdb_api_key"
             type="text"
             label="32032"
             default=""
             option="hidden"
             tooltip="32033" />

    <setting id="tv_tmdb_use_helper_api_key"
             type="bool"
             label="32034"
             default="true"
             tooltip="32037" />

    <setting id="remote_api_failure_cooldown_seconds"
             type="number"
             label="32073"
             default="120"
             min="0"
             max="3600"
             tooltip="32074" />

    <setting type="lsep" label="32059" />

    <setting id="tv_use_local_chapter_edl"
             type="bool"
             label="32028"
             default="true"
             tooltip="32061" />

    <setting id="tv_use_online_segment_lookup"
             type="bool"
             label="32029"
             default="false"
             tooltip="32062" />

    <setting id="tv_online_merge_priority"
             type="labelenum"
             label="32065"
             default="TheIntroDBFirst"
             values="TheIntroDB first|IntroDB.app first"
             optionvalues="TheIntroDBFirst|IntroDBFirst"
             tooltip="32066" />

    <setting id="tv_segment_source_priority"
             type="labelenum"
             label="32030"
             default="LocalFirst"
             values="Local first|Online first"
             optionvalues="LocalFirst|OnlineFirst"
             tooltip="32063" />

    <setting type="lsep" label="32060" />

    <setting id="movie_use_local_chapter_edl"
             type="bool"
             label="32028"
             default="true"
             tooltip="32052" />

    <setting id="movie_use_online_segment_lookup"
             type="bool"
             label="32049"
             default="false"
             tooltip="32064" />

    <setting id="movie_online_merge_priority"
             type="labelenum"
             label="32067"
             default="TheIntroDBFirst"
             values="TheIntroDB first|IntroDB.app first"
             optionvalues="TheIntroDBFirst|IntroDBFirst"
             tooltip="32068" />

    <setting id="movie_segment_source_priority"
             type="labelenum"
             label="32030"
             default="LocalFirst"
             values="Local first|Online first"
             optionvalues="LocalFirst|OnlineFirst"
             tooltip="32054" />
  </category>


  <category label="30002">

    <setting id="show_not_found_toast_for_tv_episodes" 
             type="bool" 
             label="33000" 
             default="true"
             tooltip="Show a notification if the metadata file (chapters.xml or .edl) cannot be found or read for the current episode." />

    <setting id="show_not_found_toast_for_movies" 
             type="bool" 
             label="33001" 
             default="false"
             tooltip="Show a notification if the metadata file (chapters.xml or .edl) cannot be found or read for the current movie." />

    <setting id="show_toast_for_overlapping_nested_segments" 
             type="bool" 
             label="33002" 
             default="false"
             tooltip="Show a notification if the metadata file (chapters.xml or .edl) has overlapping segments." />			 
			 
    <setting id="show_toast_for_skipped_segment" 
             type="bool" 
             label="33003" 
             default="true"
             tooltip="Show a toast notification if a segment is skipped." />					 
  </category>

  <category label="30003">
    <setting id="enable_verbose_logging"
             type="bool"
             label="34000"
             default="false"
             tooltip="34001" />
    <setting id="skippy_log_detail_level"
             type="labelenum"
             label="34002"
             default="Normal"
             values="Errors only|Normal|All detail"
             optionvalues="ErrorOnly|Normal|All"
             visible="eq(-1,true)"
             tooltip="34003" />
  </category>
</settings>
