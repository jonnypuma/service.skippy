msgid "Show Progress Bar in Skip Dialog"
msgstr "Εμφάνιση Γραμμής Προόδου στον Διάλογο Παράλειψης"

msgctxt "#32008"
msgid "Major Rewind Threshold (Seconds)"
msgstr "Όριο Μεγάλης Επιστροφής (Δευτερόλεπτα)"

msgctxt "#32009"
msgid "Skip Dialog Position"
msgstr "Θέση Διαλόγου Παράλειψης"

msgctxt "#32010"
msgid "Enable Skip for Movies"
msgstr "Ενεργοποίηση Παράλειψης για Ταινίες"

msgctxt "#32011"
msgid "Enable Skip for Episodes"
msgstr "Ενεργοποίηση Παράλειψης για Επεισόδια"

msgctxt "#32017"
