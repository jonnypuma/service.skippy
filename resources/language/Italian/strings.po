# Categories
msgctxt "#30000"
msgid "Segment Settings"
msgstr "Impostazioni segmenti"

msgctxt "#30001"
msgid "Playback & Skip Dialog"
msgstr "Riproduzione e finestra di salto"

msgctxt "#30004"
msgid "Segment Sources"
msgstr "Sorgenti segmenti"

msgctxt "#30002"
