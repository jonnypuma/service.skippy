msgctxt "#36000"
msgid "Enable Segment Marker"
msgstr "Enable Segment Marker"

msgctxt "#36001"
msgid "Mark segment start/end times during playback with a configurable hotkey (default: CTRL+E) or remote button. After marking start and end, choose a segment type and save to sidecar files."
msgstr "Mark segment start/end times during playback with a configurable hotkey (default: CTRL+E) or remote button. After marking start and end, choose a segment type and save to sidecar files."

msgctxt "#36002"
msgid "Auto-save marked segments"
msgstr "Auto-save marked segments"

msgctxt "#36003"
msgid "When enabled, segments are saved immediately after selecting the segment type without a confirmation prompt."
msgstr "When enabled, segments are saved immediately after selecting the segment type without a confirmation prompt."

msgctxt "#36004"
msgid "Show pending marker indicator"
msgstr "Show pending marker indicator"

msgctxt "#36005"
msgid "While waiting for the second marker press, shows a semi-transparent label at the top-left of the screen (during playback) with the pending start time. After you set the end time, it shows the full range until you finish or cancel saving. Requires the Skippy service to be running."
msgstr "While waiting for the second marker press, shows a semi-transparent label at the top-left of the screen (during playback) with the pending start time. After you set the end time, it shows the full range until you finish or cancel saving. Requires the Skippy service to be running."

msgctxt "#36006"
msgid "Saved file permissions"
msgstr "Saved file permissions"

msgctxt "#36007"
msgid "Permissions applied after saving EDL/chapters files. Leave unchanged: Skippy does not call chmod; the file keeps whatever mode the OS or Kodi created (umask / platform default). 644: owner read/write, group and others read only. 666: all users read/write (use sparingly; sometimes used on shared folders)."
msgstr "Permissions applied after saving EDL/chapters files. Leave unchanged: Skippy does not call chmod; the file keeps whatever mode the OS or Kodi created (umask / platform default). 644: owner read/write, group and others read only. 666: all users read/write (use sparingly; sometimes used on shared folders)."

msgctxt "#36008"
msgid "Start time set"
msgstr "Start time set"

msgctxt "#36009"
msgid "End time set"
msgstr "End time set"

msgctxt "#36010"
msgid "Choose segment type"
msgstr "Choose segment type"

msgctxt "#36011"
msgid "Save segment?"
msgstr "Save segment?"

msgctxt "#36012"
msgid "Segment saved"
msgstr "Segment saved"

msgctxt "#36013"
msgid "Error saving segment"
msgstr "Error saving segment"

msgctxt "#36014"
msgid "Cancelled"
msgstr "Cancelled"

msgctxt "#36015"
msgid "No video playing"
msgstr "No video playing"

msgctxt "#36016"
msgid "Segment Marker disabled"
msgstr "Segment Marker disabled"

msgctxt "#36017"
msgid "Save format"
msgstr "Save format"

msgctxt "#36018"
msgid "Choose which sidecar file format(s) to save marked segments to. Both: saves to .edl and -chapters.xml. EDL only: saves to .edl file. Chapters XML only: saves to -chapters.xml file."
msgstr "Choose which sidecar file format(s) to save marked segments to. Both: saves to .edl and -chapters.xml. EDL only: saves to .edl file. Chapters XML only: saves to -chapters.xml file."

msgctxt "#36019"
msgid "Keyboard marker shortcut"
msgstr "Keyboard marker shortcut"

msgctxt "#36020"
msgid "Type the Kodi keyboard shortcut to write to userdata/keymaps/skippy_marker.xml. Examples: ctrl+e, e, f9, ctrl+shift+m. Use Keyboard marker press type below for normal press vs long press. The keymap is refreshed automatically when settings change."
msgstr "Type the Kodi keyboard shortcut to write to userdata/keymaps/skippy_marker.xml. Examples: ctrl+e, e, f9, ctrl+shift+m. Use Keyboard marker press type below for normal press vs long press. The keymap is refreshed automatically when settings change."

msgctxt "#36021"
msgid "Remote marker button"
msgstr "Remote marker button"

msgctxt "#36022"
msgid "Optional Kodi remote button name (red, green, blue, yellow, record, select, info, etc.) or discovered raw key code (for example key:61505). CEC remotes usually save as button names; Bluetooth/remotes with raw codes usually save as key:<code>. Leave empty when only using the keyboard hotkey."
msgstr "Optional Kodi remote button name (red, green, blue, yellow, record, select, info, etc.) or discovered raw key code (for example key:61505). CEC remotes usually save as button names; Bluetooth/remotes with raw codes usually save as key:<code>. Leave empty when only using the keyboard hotkey."

msgctxt "#36023"
msgid "Discover remote button code"
msgstr "Discover remote button code"

msgctxt "#36024"
msgid "Opens a small capture dialog. Press the remote button you want to use; Skippy stores the button code in the Remote marker button setting and updates the keymap. Use Remote marker press type to choose normal press or long press."
msgstr "Opens a small capture dialog. Press the remote button you want to use; Skippy stores the button code in the Remote marker button setting and updates the keymap. Use Remote marker press type to choose normal press or long press."

msgctxt "#36025"
msgid "Update marker keymap now"
msgstr "Update marker keymap now"

msgctxt "#36026"
msgid "Writes the current keyboard and remote marker settings to Kodi's userdata keymap and reloads keymaps."
msgstr "Writes the current keyboard and remote marker settings to Kodi's userdata keymap and reloads keymaps."

msgctxt "#36027"
msgid "Remote marker press type"
msgstr "Remote marker press type"

msgctxt "#36028"
msgid "Choose whether the configured remote marker button triggers on a normal press or long press. For discovered raw key codes, Skippy writes this as a keymap longpress modifier."
msgstr "Choose whether the configured remote marker button triggers on a normal press or long press. For discovered raw key codes, Skippy writes this as a keymap longpress modifier."

msgctxt "#36029"
msgid "Keyboard marker press type"
msgstr "Keyboard marker press type"

msgctxt "#36030"
msgid "Choose whether the configured keyboard shortcut triggers on a normal press or long press. Default is normal press."
msgstr "Choose whether the configured keyboard shortcut triggers on a normal press or long press. Default is normal press."

msgctxt "#36031"
msgid "How to save marked segments"
msgstr "How to save marked segments"

msgctxt "#36032"
msgid "Controls how Segment Marker combines a new marked range with existing EDL/XML sidecar entries. Merge non-overlapping: add the marker only when it does not overlap existing entries. Keep both (old starts after new): add the new segment and shorten any overlapping existing segment so it starts where the new one ends (drops the old entry if the new range fully covers it). Overwrite overlapping: remove overlapping entries and add the new one. Append always: add the new entry even if it overlaps. Replace file: write only the newly marked segment. Ask each time: choose during marker save, before selecting the segment type."
msgstr "Controls how Segment Marker combines a new marked range with existing EDL/XML sidecar entries. Merge non-overlapping: add the marker only when it does not overlap existing entries. Keep both (old starts after new): add the new segment and shorten any overlapping existing segment so it starts where the new one ends (drops the old entry if the new range fully covers it). Overwrite overlapping: remove overlapping entries and add the new one. Append always: add the new entry even if it overlaps. Replace file: write only the newly marked segment. Ask each time: choose during marker save, before selecting the segment type."

msgctxt "#36033"
msgid "Back up files before marker save"
msgstr "Back up files before marker save"

msgctxt "#36034"
msgid "Before saving, back up existing sidecar files selected by Save format. EDL only backs up .edl, Chapters XML only backs up chapter XML, Both backs up both when they exist. Backups use the same path with a .bck extension."
msgstr "Before saving, back up existing sidecar files selected by Save format. EDL only backs up .edl, Chapters XML only backs up chapter XML, Both backs up both when they exist. Backups use the same path with a .bck extension."
