msgstr "Prefer when both local and online are enabled"

msgctxt "#32036"
msgid "Online APIs (TMDB)"
msgstr "Online APIs (TMDB)"

msgctxt "#32031"
msgid "Resolve missing TMDB / IMDb via TMDB API"
msgstr "Resolve missing TMDB / IMDb via TMDB API"

msgctxt "#32032"
msgid "TMDB API key (optional)"
msgstr "TMDB API key (optional)"

msgctxt "#32033"
msgid "Free key from themoviedb.org (Settings → API). Used when TV or movie online lookup needs to resolve missing TMDB/IMDb ids. Leave empty to use TheMovieDB Helper’s key below (same key for episodes and movies)."
msgstr "Free key from themoviedb.org (Settings → API). Used when TV or movie online lookup needs to resolve missing TMDB/IMDb ids. Leave empty to use TheMovieDB Helper’s key below (same key for episodes and movies)."

msgctxt "#32034"
msgid "Use TheMovieDB Helper addon API key when empty"
msgstr "Use TheMovieDB Helper addon API key when empty"

msgctxt "#32035"
msgid "When TV or movie online lookup is enabled and Kodi has no TMDB/IMDb in uniqueid, call api.themoviedb.org to fill gaps (same IDs TheIntroDB / IntroDB.app need). Applies to both episodes and movies. Disable to use only library scraper metadata."
msgstr "When TV or movie online lookup is enabled and Kodi has no TMDB/IMDb in uniqueid, call api.themoviedb.org to fill gaps (same IDs TheIntroDB / IntroDB.app need). Applies to both episodes and movies. Disable to use only library scraper metadata."

msgctxt "#32037"
msgid "If the TMDB API key field above is empty, read the key from plugin.video.themoviedb.helper when installed. One key for both TV episodes and movies."
msgstr "If the TMDB API key field above is empty, read the key from plugin.video.themoviedb.helper when installed. One key for both TV episodes and movies."

msgctxt "#32059"
msgid "TV episodes"
msgstr "TV episodes"

msgctxt "#32060"
msgid "Movies"
msgstr "Movies"

msgctxt "#32061"
msgid "When enabled, TV episodes load skip segments from sidecar chapters.xml or .edl next to the video."
msgstr "When enabled, TV episodes load skip segments from sidecar chapters.xml or .edl next to the video."

msgctxt "#32062"
msgid "When enabled, TV episodes can load intro/recap timing from TheIntroDB and IntroDB.app. Requires season/episode and TMDB/IMDb-style IDs from Kodi’s library (scraper uniqueid). SxxExx in the filename is only a fallback when the item is not in the library."
msgstr "When enabled, TV episodes can load intro/recap timing from TheIntroDB and IntroDB.app. Requires season/episode and TMDB/IMDb-style IDs from Kodi’s library (scraper uniqueid). SxxExx in the filename is only a fallback when the item is not in the library."

msgctxt "#32063"
msgid "When both local files and online lookup are enabled for TV episodes: prefer segments from the chosen source when it has data; otherwise use the other."
msgstr "When both local files and online lookup are enabled for TV episodes: prefer segments from the chosen source when it has data; otherwise use the other."

msgctxt "#32064"
msgid "When enabled, movies can load intro/recap timing from TheIntroDB only (not IntroDB.app). Requires TMDB and/or IMDb movie ids from Kodi’s library (uniqueid), or the global TMDB API settings above when ids are missing."
msgstr "When enabled, movies can load intro/recap timing from TheIntroDB only (not IntroDB.app). Requires TMDB and/or IMDb movie ids from Kodi’s library (uniqueid), or the global TMDB API settings above when ids are missing."

msgctxt "#32065"
msgid "TV episodes: online API priority"
msgstr "TV episodes: online API priority"

msgctxt "#32066"
msgid "When TheIntroDB and IntroDB.app both return a segment for the same time range, the API you list first wins for that window; the other’s overlapping entry is omitted. The other API can still add segments that do not overlap that window."
msgstr "When TheIntroDB and IntroDB.app both return a segment for the same time range, the API you list first wins for that window; the other’s overlapping entry is omitted. The other API can still add segments that do not overlap that window."

msgctxt "#32067"
msgid "Movies: online API priority"
msgstr "Movies: online API priority"

msgctxt "#32068"
msgid "Same rule as for TV episodes. For movies, only TheIntroDB is used today (IntroDB.app has no movie segments); this setting stays for consistency if that changes later."
msgstr "Same rule as for TV episodes. For movies, only TheIntroDB is used today (IntroDB.app has no movie segments); this setting stays for consistency if that changes later."

msgctxt "#32073"
msgid "Seconds to pause remote API calls after errors"
msgstr "Seconds to pause remote API calls after errors"

msgctxt "#32074"
msgid "Base seconds for backoff after errors (each host separate). Each new failure doubles wait time up to 3600 s until a request succeeds (exponential backoff). HTTP 429 may include Retry-After; when present, Skippy uses at least that many seconds (still capped at 3600). HTTP 404 does not trigger backoff. Set to 0 to disable."
msgstr "Base seconds for backoff after errors (each host separate). Each new failure doubles wait time up to 3600 s until a request succeeds (exponential backoff). HTTP 429 may include Retry-After; when present, Skippy uses at least that many seconds (still capped at 3600). HTTP 404 does not trigger backoff. Set to 0 to disable."

msgctxt "#32075"
msgid "Pre-fetch segments for next episode"
msgstr "Pre-fetch segments for next episode"

msgctxt "#32076"
msgid "When TV online lookup is enabled and a playlist contains more episodes, Skippy pre-fetches segment data for the next episode in the background so it is ready when playback transitions."
msgstr "When TV online lookup is enabled and a playlist contains more episodes, Skippy pre-fetches segment data for the next episode in the background so it is ready when playback transitions."

msgctxt "#32045"
msgid "Online segments sidecar"
msgstr "Online segments sidecar"

msgctxt "#32077"
msgid "Save format (online segments)"
msgstr "Save format (online segments)"

msgctxt "#32078"
msgid "Write fetched online segments to `.edl` next to the video, to Matroska-style `-chapters.xml` / `_chapters.xml`, or both. Separate from Segment Marker save format."
msgstr "Write fetched online segments to `.edl` next to the video, to Matroska-style `-chapters.xml` / `_chapters.xml`, or both. Separate from Segment Marker save format."

msgctxt "#32046"
msgid "Save online segments"
msgstr "Save online segments"

msgctxt "#32047"
msgid "When online lookup returns segment windows and this is on, Skippy writes them to disk using the save format and the policies below (skip / overwrite / merge / update / backup). Does not apply to plugin playback, .strm files, or common stream URLs."
msgstr "When online lookup returns segment windows and this is on, Skippy writes them to disk using the save format and the policies below (skip / overwrite / merge / update / backup). Does not apply to plugin playback, .strm files, or common stream URLs."

msgctxt "#32069"
msgid "If matching sidecar already exists"
msgstr "If matching sidecar already exists"

msgctxt "#32070"
msgid "Applies separately to each sidecar type you save (.edl and/or chapters.xml). Skip: do nothing when that file already exists. Overwrite: replace it with online segments only (optional prompt). Merge: keep existing entries and add online segments that do not overlap an existing time range. Update: adjust start/end on local segments that match online (intro/recap/credits/preview; IntroDB outro matches credits); never remove locals; optional prompt."
msgstr "Applies separately to each sidecar type you save (.edl and/or chapters.xml). Skip: do nothing when that file already exists. Overwrite: replace it with online segments only (optional prompt). Merge: keep existing entries and add online segments that do not overlap an existing time range. Update: adjust start/end on local segments that match online (intro/recap/credits/preview; IntroDB outro matches credits); never remove locals; optional prompt."

msgctxt "#32071"
msgid "Back up sidecar files before overwrite, merge, or update"
msgstr "Back up sidecar files before overwrite, merge, or update"

msgctxt "#32072"
msgid "When enabled, an existing `.edl` or chapter XML file is copied to the same path with an extra `.bck` extension immediately before it is replaced, merged, or updated."
msgstr "When enabled, an existing `.edl` or chapter XML file is copied to the same path with an extra `.bck` extension immediately before it is replaced, merged, or updated."

msgctxt "#35000"
msgid "Replace local files with online segment data?"
msgstr "Replace local files with online segment data?"

msgctxt "#35001"
msgid "A sidecar file already exists for this video. Replace it with online segments only? (Existing content will be lost unless you enabled backup or chose Merge in settings.)"
msgstr "A sidecar file already exists for this video. Replace it with online segments only? (Existing content will be lost unless you enabled backup or chose Merge in settings.)"

msgctxt "#35002"
msgid "Replace local chapter XML and EDL with online data?"
msgstr "Replace local chapter XML and EDL with online data?"

msgctxt "#35003"
msgid "Both a chapter XML file and an `.edl` already exist beside this video. Replace both with segments from online lookup? (Existing content will be lost unless backup is enabled in settings or you use Merge policy.)"
msgstr "Both a chapter XML file and an `.edl` already exist beside this video. Replace both with segments from online lookup? (Existing content will be lost unless backup is enabled in settings or you use Merge policy.)"

msgctxt "#35004"
msgid "Existing chapter XML will be replaced by segments from online lookup. Continue? (Copies to `.bck` first if backup is enabled. Use Merge in settings to combine instead.)"
msgstr "Existing chapter XML will be replaced by segments from online lookup. Continue? (Copies to `.bck` first if backup is enabled. Use Merge in settings to combine instead.)"

msgctxt "#35005"
msgid "Existing `.edl` will be replaced by segments from online lookup. Continue? (Copies to `.bck` first if backup is enabled. Use Merge in settings to combine instead.)"
msgstr "Existing `.edl` will be replaced by segments from online lookup. Continue? (Copies to `.bck` first if backup is enabled. Use Merge in settings to combine instead.)"

msgctxt "#35012"
msgid "Update chapter XML from online?"
msgstr "Update chapter XML from online?"

msgctxt "#35013"
msgid "Matched local chapters (intro / recap / credits / preview — IntroDB outro matches credits) will get new start/end times from online lookup. Other chapters are unchanged; none are removed. Continue? (Copies to `.bck` first if backup is enabled.)"
msgstr "Matched local chapters (intro / recap / credits / preview — IntroDB outro matches credits) will get new start/end times from online lookup. Other chapters are unchanged; none are removed. Continue? (Copies to `.bck` first if backup is enabled.)"

msgctxt "#35014"
msgid "Update EDL from online?"
msgstr "Update EDL from online?"

msgctxt "#35015"
msgid "Matched local segment rows will get new times from online lookup (same rules as chapter XML update). Unmatched rows stay as-is. Continue? (Copies to `.bck` first if backup is enabled.)"
msgstr "Matched local segment rows will get new times from online lookup (same rules as chapter XML update). Unmatched rows stay as-is. Continue? (Copies to `.bck` first if backup is enabled.)"

msgctxt "#35016"
msgid "Update chapter XML and EDL from online?"
msgstr "Update chapter XML and EDL from online?"

msgctxt "#35017"
msgid "Both sidecars exist: Skippy will update only matched local segments with online times (see Update policy help). Unmatched entries stay; none are removed. Continue? (Copies to `.bck` first if backup is enabled.)"
msgstr "Both sidecars exist: Skippy will update only matched local segments with online times (see Update policy help). Unmatched entries stay; none are removed. Continue? (Copies to `.bck` first if backup is enabled.)"

msgctxt "#32052"
msgid "When enabled, movies load skip segments from sidecar chapters.xml or .edl next to the video."
msgstr "When enabled, movies load skip segments from sidecar chapters.xml or .edl next to the video."

msgctxt "#32054"
msgid "When both local files and online lookup are enabled for movies: prefer segments from the chosen source when it has data; otherwise use the other."
msgstr "When both local files and online lookup are enabled for movies: prefer segments from the chosen source when it has data; otherwise use the other."

