msgstr "Configuración de segmentos"

msgctxt "#30001"
msgid "Playback & Skip Dialog"
msgstr "Reproducción y diálogo de salto"

msgctxt "#30004"
msgid "Segment Sources"
msgstr "Fuentes de segmentos"

