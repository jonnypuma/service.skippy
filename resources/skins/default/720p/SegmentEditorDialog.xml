<?xml version="1.0" encoding="UTF-8"?>
<window>
  <coordinates>
    <system>1</system>
    <posx>0</posx>
    <posy>0</posy>
    <width>1920</width>
    <height>1080</height>
  </coordinates>

  <zorder>1</zorder>
  <defaultcontrol>5018</defaultcontrol>

  <animation type="WindowOpen">
    <effect type="slide" start="0,100" end="0,0" time="300" tween="quadratic" easing="out" />
    <effect type="fade" start="0" end="100" time="400" />
  </animation>

  <animation type="WindowClose">
    <effect type="slide" start="0,0" end="0,100" time="300" tween="quadratic" easing="in" />
    <effect type="fade" start="100" end="0" time="300" />
  </animation>

  <controls>
    <!-- Background - semi-transparent black overlay like Skippy -->
    <!-- Only visible if EnableFullscreenOverlay property is set to "true" -->
    <control type="image">
      <left>0</left>
      <top>0</top>
      <width>1920</width>
      <height>1080</height>
      <texture>white.png</texture>
      <colordiffuse>F0000000</colordiffuse>
      <visible>String.IsEqual(Window.Property(EnableFullscreenOverlay),true)</visible>
    </control>

    <!-- Main panel - centered and sized to fit within video window -->
    <control type="group">
      <left>50</left>
      <top>60</top>
      <width>1170</width>
      <height>570</height>

      <!-- Panel background - darker semi-transparent background -->
      <control type="image">
        <left>0</left>
        <top>0</top>
        <width>1170</width>
        <height>570</height>
        <texture>white.png</texture>
        <colordiffuse>F0202020</colordiffuse>
      </control>

      <!-- Title banner (top-left, proportional — do not stretch full width) -->
