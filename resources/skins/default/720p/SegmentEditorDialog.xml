        <left>20</left>
        <top>20</top>
        <width>229</width>
        <height>40</height>
        <texture>segment_editor_banner.png</texture>
        <aspectratio aligny="center">keep</aspectratio>
      </control>

      <!-- Current time label -->
      <control type="label" id="5001">
        <left>20</left>
        <top>70</top>
        <width>480</width>
        <height>30</height>
        <label>Current Time: --:--:--</label>
        <font>font16</font>
        <textcolor>FFB0D4E8</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>1</shadowoffsetx>
        <shadowoffsety>1</shadowoffsety>
        <align>left</align>
      </control>

