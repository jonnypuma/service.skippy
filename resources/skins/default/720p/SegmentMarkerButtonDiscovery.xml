<?xml version="1.0" encoding="UTF-8"?>
<window>
  <coordinates>
    <system>1</system>
    <posx>0</posx>
    <posy>0</posy>
    <width>1280</width>
    <height>720</height>
  </coordinates>

  <zorder>2</zorder>

  <animation type="WindowOpen">
    <effect type="fade" start="0" end="100" time="150" />
  </animation>
  <animation type="WindowClose">
    <effect type="fade" start="100" end="0" time="100" />
  </animation>

  <controls>
    <control type="image">
      <left>0</left>
      <top>0</top>
      <width>1280</width>
      <height>720</height>
      <texture>white.png</texture>
      <colordiffuse>80000000</colordiffuse>
    </control>

    <control type="group">
      <left>250</left>
      <top>220</top>
      <width>780</width>
      <height>280</height>

      <control type="image">
        <left>0</left>
        <top>0</top>
        <width>780</width>
        <height>280</height>
        <texture>white.png</texture>
        <colordiffuse>F0202020</colordiffuse>
      </control>

      <control type="label">
        <left>30</left>
        <top>28</top>
        <width>720</width>
        <height>45</height>
        <label>Skippy Remote Button Discovery</label>
        <font>font30</font>
        <textcolor>FFFFFFFF</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>2</shadowoffsetx>
        <shadowoffsety>2</shadowoffsety>
      </control>

      <control type="label">
        <left>30</left>
        <top>92</top>
        <width>720</width>
        <height>35</height>
        <label>Press the remote button to use for Segment Marker.</label>
        <font>font14</font>
        <textcolor>FFB0D4E8</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>1</shadowoffsetx>
        <shadowoffsety>1</shadowoffsety>
      </control>

      <control type="label">
        <left>30</left>
        <top>132</top>
        <width>720</width>
        <height>35</height>
        <label>Plain keyboard character input is ignored.</label>
        <font>font14</font>
        <textcolor>FFFFFFFF</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>1</shadowoffsetx>
        <shadowoffsety>1</shadowoffsety>
      </control>

      <control type="label">
        <left>30</left>
        <top>172</top>
        <width>720</width>
        <height>35</height>
        <label>Skippy stores accepted raw codes as key:&lt;code&gt; and closes automatically.</label>
        <font>font14</font>
        <textcolor>FFFFFFFF</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>1</shadowoffsetx>
        <shadowoffsety>1</shadowoffsety>
      </control>

      <control type="label">
        <left>30</left>
        <top>222</top>
        <width>720</width>
        <height>30</height>
        <label>Back/Esc cancels.</label>
        <font>font12</font>
        <textcolor>FFB0B0B0</textcolor>
        <shadowcolor>FF000000</shadowcolor>
        <shadowoffsetx>1</shadowoffsetx>
        <shadowoffsety>1</shadowoffsety>
      </control>
    </control>
  </controls>
</window>
